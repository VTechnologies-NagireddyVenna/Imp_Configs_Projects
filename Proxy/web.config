<?xml version="1.0" encoding="utf-8"?>
<configuration>

  <system.webServer>

    <rewrite>
      <rules>

        <rule name="ReverseProxy" stopProcessing="true">

          <match url="(.*)" />

          <action type="Rewrite"
                  url="http://127.0.0.1:8081/{R:1}" />

        </rule>

      </rules>
    </rewrite>

  </system.webServer>

</configuration>
